rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ─── Products: public read, admin write ──────────────────────────────────
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Categories: public read, admin write ───────────────────────────────
    match /categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Orders: customer creates own, admin reads/writes all ────────────────
    match /orders/{id} {
      allow create: if true;  // guest checkout via WhatsApp flow
      allow read, update, delete: if isAdmin();
    }

    // ─── Settings: public read, admin write ─────────────────────────────────
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Admins: admin only ──────────────────────────────────────────────────
    match /admins/{uid} {
      allow read, write: if isAdmin();
    }
  }
}
